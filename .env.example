# =============================================================
# .env.example - Template cấu hình môi trường
# Smart Campus B6 - Core Business API
# =============================================================
#
# HƯỚNG DẪN:
# 1. Copy file này thành .env:  cp .env.example .env
# 2. Điền các giá trị thực tế vào file .env
# 3. KHÔNG BAO GIỜ commit file .env lên Git (đã có trong .gitignore)
# =============================================================


# ----------------------------
# CẤU HÌNH JWT (BẮT BUỘC)
# ----------------------------
# Secret key để ký JWT Token. Phải là chuỗi ngẫu nhiên dài và bí mật.
# Tạo key mạnh bằng lệnh: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars


# ----------------------------
# CẤU HÌNH DATABASE (BẮT BUỘC)
# ----------------------------
# Khi chạy LOCAL (không Docker): dùng localhost
DATABASE_URL=mysql+pymysql://campus_user:campus_password@localhost:3306/smart_campus_db

# Khi chạy trong Docker Compose: dùng hostname 'db' (service name)
# DATABASE_URL sẽ được docker-compose.yml override tự động

# Thông tin MySQL (dùng cho Docker Compose)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=smart_campus_db
MYSQL_USER=campus_user
MYSQL_PASSWORD=campus_password


# ----------------------------
# CẤU HÌNH GIAO TIẾP PHÂN HỆ
# ----------------------------
# URL của phân hệ B3 (Access Gate) để ra lệnh mở cổng
B3_API_URL=http://localhost:8003/api/v1/gate/open

# URL của phân hệ B7 (Notification) để gửi cảnh báo
B7_API_URL=http://localhost:8007/api/v1/alerts


# ----------------------------
# CẤU HÌNH MÔI TRƯỜNG (tuỳ chọn)
# ----------------------------
# development | production | testing
APP_ENV=development
