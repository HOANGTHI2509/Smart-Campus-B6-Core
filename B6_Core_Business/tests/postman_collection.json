							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Server từ chối mở cửa (allowed: false)\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.allowed).to.be.false;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
