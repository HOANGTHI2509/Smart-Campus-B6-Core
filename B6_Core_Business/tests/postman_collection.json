			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Trạng thái HTTP phải là 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Server cho phép mở cửa (allowed: true)\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.allowed).to.be.true;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{"key": "Content-Type", "value": "application/json"}],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"gateId\": \"GATE_A_01\",\r\n  \"uid\": \"04:A1:B2:C3\",\r\n  \"timestamp\": \"2026-06-16T20:00:00Z\"\r\n}"
				},
				"url": {
					"raw": "{{BASE_URL}}/access/check",
					"host": ["{{BASE_URL}}"],
					"path": ["access", "check"]
