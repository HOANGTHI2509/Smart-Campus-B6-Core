{
	"info": {
		"_postman_id": "b6-core-mock-test-advanced",
		"name": "B6 Core Business - Automated Regression Tests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. GET Health Check (Happy Path)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Trạng thái HTTP phải là 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Thời gian phản hồi phải dưới 500ms\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(500);",
							"});",
							"pm.test(\"Hệ thống trả về status: ok\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.status).to.eql(\"ok\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{BASE_URL}}/health",
					"host": ["{{BASE_URL}}"],
					"path": ["health"]
				}
			}
		},
		{
			"name": "2. POST AI Vision Webhook (Happy Path)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Trạng thái HTTP phải là 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"B6 ghi nhận thành công cảnh báo từ B4\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.message).to.include(\"successfully\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [{"key": "Content-Type", "value": "application/json"}],
				"body": {
					"mode": "raw",
					"raw": "{\r\n  \"detectionId\": \"string\",\r\n  \"cameraId\": \"string\",\r\n  \"detectionType\": \"OBJECT\",\r\n  \"riskLevel\": \"CRITICAL\",\r\n  \"timestamp\": \"2026-06-16T20:00:00Z\"\r\n}"
				},
				"url": {
					"raw": "{{BASE_URL}}/ai/events",
					"host": ["{{BASE_URL}}"],
					"path": ["ai", "events"]
				}
			}
		},
		{
