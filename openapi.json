        },
        "type": "object",
        "required": [
          "card_uid",
          "gate_id"
        ],
        "title": "AccessCheckRequest"
      },
      "AccessCheckResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "is_granted": {
            "type": "boolean",
            "title": "Is Granted"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "user_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "User Name"
          }
        },
        "type": "object",
        "required": [
          "status",
          "is_granted",
          "message"
        ],
        "title": "AccessCheckResponse"
      },
      "Body_login_for_access_token_api_v1_access_login_post": {
        "properties": {
          "grant_type": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^password$"
              },
              {
                "type": "null"
              }
            ],
